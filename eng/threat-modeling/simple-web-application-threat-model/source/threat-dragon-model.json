            "id": "7c40de81-ebcb-46ea-a3a8-df1380886f1c",
            "data": {
              "type": "tm.Process",
              "name": "React Frontend",
              "description": "Validation:\nUse SAST and code review to identify console.log(), console.info(), console.debug(), and other debug statements that may expose tokens, personal data, API responses, internal identifiers, or implementation details.\n\nUse DAST as a supporting check by reviewing the browser console and runtime errors in the production build.\n\nValidation status:\nNot tested. Hypothetical threat model.",
              "outOfScope": false,
              "isTrustBoundary": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "handlesCardPayment": false,
              "handlesGoodsOrServices": false,
              "isWebApplication": false,
              "privilegeLevel": "",
              "threats": [
                {
                  "id": "95b69e64-f159-4df2-b9c5-7c89c073f970",
                  "title": "Sensitive Information Exposed in Browser Console",
                  "status": "Open",
                  "severity": "Medium",
                  "type": "Information disclosure",
                  "description": "The React application may expose sensitive information through console.log(), console.info(), console.debug(), or unhandled error messages. This may include API responses, tokens, user data, internal identifiers, feature flags, or implementation details.\n",
                  "mitigation": "Remove debug logging from production builds. Never log tokens, credentials, personal data, or complete API responses. Use a controlled logging utility, environment-based log levels, and review production bundles for debug statements.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 6,
                  "score": ""
                }
              ],
              "threatFrequency": {
                "spoofing": 0,
                "tampering": 0,
                "repudiation": 0,
                "informationDisclosure": 1,
                "denialOfService": 0,
                "elevationOfPrivilege": 0
              }
            }
