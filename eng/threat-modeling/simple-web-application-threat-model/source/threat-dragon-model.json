            "id": "448dfaf2-7959-4aca-aeec-31b99b621999",
            "data": {
              "type": "tm.Process",
              "name": "Browser",
              "description": "An attacker who steals a session cookie or access token may impersonate a legitimate user.\n\nValidation:\nVerify that session cookies use the Secure, HttpOnly and appropriate SameSite attributes. Check that tokens are not stored in localStorage unless there is a justified design reason, sessions expire correctly, and logout invalidates the active session.\n\nValidation status:\nNot tested. Hypothetical threat model.",
              "outOfScope": false,
              "isTrustBoundary": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "handlesCardPayment": false,
              "handlesGoodsOrServices": false,
              "isWebApplication": false,
              "privilegeLevel": "",
              "threats": [
                {
                  "id": "f639ab3f-2570-4d10-b4a8-01efb024209f",
                  "title": "Session or Token Theft",
                  "status": "Open",
                  "severity": "High",
                  "type": "Spoofing",
                  "description": "An attacker who steals a session cookie or access token may impersonate a legitimate user.\n",
                  "mitigation": "Use Secure, HttpOnly and appropriate SameSite cookie settings. Protect against XSS, rotate tokens, expire sessions and invalidate compromised sessions.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 3,
                  "score": ""
                }
              ],
              "threatFrequency": {
                "spoofing": 1,
                "tampering": 0,
                "repudiation": 0,
                "informationDisclosure": 0,
                "denialOfService": 0,
                "elevationOfPrivilege": 0
