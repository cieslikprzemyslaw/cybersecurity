        <mxCell id="r3-c4" value="The application reveals account-existence information that an unauthorised party should not receive." style="text;html=1;align=left;verticalAlign=top;spacing=6;whiteSpace=wrap;overflow=hidden;strokeColor=#999999;fillColor=#ffffff;fontSize=10;" vertex="1" parent="1">
