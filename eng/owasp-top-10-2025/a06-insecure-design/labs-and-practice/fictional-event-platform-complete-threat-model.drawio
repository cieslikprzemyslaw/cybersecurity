        <mxCell id="r3-c6" value="Open" style="text;html=1;align=center;verticalAlign=middle;spacing=4;whiteSpace=wrap;overflow=hidden;strokeColor=#999999;fillColor=#ffffff;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1350" y="356" width="80" height="68" as="geometry" />
        </mxCell>
        <mxCell id="r4-c0" value="T-005" style="text;html=1;align=center;verticalAlign=middle;spacing=4;whiteSpace=wrap;overflow=hidden;strokeColor=#999999;fillColor=#ffffff;fontSize=10;" vertex="1" parent="1">
