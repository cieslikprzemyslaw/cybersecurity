        <mxCell id="r3-c0" value="T-004" style="text;html=1;align=center;verticalAlign=middle;spacing=4;whiteSpace=wrap;overflow=hidden;strokeColor=#999999;fillColor=#ffffff;fontSize=10;" vertex="1" parent="1">
