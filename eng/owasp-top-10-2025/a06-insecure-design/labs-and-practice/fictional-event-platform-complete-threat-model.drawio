          <mxGeometry relative="1" x="0.5265" as="geometry">
            <mxPoint x="15" y="-10" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="yiW97cX9BBf8rP341d2M-103" parent="1" style="shape=umlActor;verticalLabelPosition=top;verticalAlign=bottom;html=1;outlineConnect=0;labelPosition=center;align=center;" value="&#10;Platform Administrator&#10;&#10;" vertex="1">
