        <mxCell id="r3-c2" value="Auth Service → API Gateway authentication and recovery responses" style="text;html=1;align=left;verticalAlign=top;spacing=6;whiteSpace=wrap;overflow=hidden;strokeColor=#999999;fillColor=#ffffff;fontSize=10;" vertex="1" parent="1">
